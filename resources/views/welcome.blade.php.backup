                            <!-- Hidden inputs for form submission -->
                            <input type="hidden" name="include_flight" :value="bundleFlight ? 1 : 0">
                            <input type="hidden" name="include_hotel" :value="bundleHotel ? 1 : 0">
                            <input type="hidden" name="include_car" :value="bundleCar ? 1 : 0">
