                    ['from' => 'Los Angeles', 'to' => 'Tokyo', 'airline' => 'Multiple Airlines', 'date' => 'Jan 10 - Jan 20'],
                    ['from' => 'Miami', 'to' => 'Dubai', 'airline' => 'Multiple Airlines', 'date' => 'Dec 20 - Jan 5'],
