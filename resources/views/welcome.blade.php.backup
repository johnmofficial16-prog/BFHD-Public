                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zM8.5 9.5L7 11l4 4 6-6-1.5-1.5L11 12 8.5 9.5z"/></svg>
